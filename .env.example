# ---- DQ Sentinel configuration (all values have dev defaults) ----

# App metadata database. Default: sqlite file under backend/.
# For production use PostgreSQL, e.g.:
# DQ_DATABASE_URL=postgresql+psycopg://dq:dq@localhost:5432/dqsentinel
DQ_DATABASE_URL=

# JWT signing secret — REQUIRED in production (any long random string)
DQ_SECRET_KEY=dev-only-secret-change-me
DQ_ACCESS_TOKEN_HOURS=12

# Seeded first admin (created only if no users exist)
DQ_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
DQ_BOOTSTRAP_ADMIN_PASSWORD=admin123

# ---- LLM (optional; provider-agnostic) ----
# Without any key the app falls back to heuristic generation/suggestions.
# DQ_LLM_PROVIDER: auto | anthropic | openai | openrouter
#   auto = anthropic if ANTHROPIC_API_KEY set, else openai-compatible if DQ_LLM_API_KEY set
DQ_LLM_PROVIDER=auto

# Option A — native Anthropic:
ANTHROPIC_API_KEY=
# DQ_LLM_MODEL=claude-opus-4-8        # default for the anthropic provider

# Option B — ANY OpenAI-compatible endpoint (OpenRouter, vLLM, Ollama, Together...):
DQ_LLM_API_KEY=
DQ_LLM_BASE_URL=https://openrouter.ai/api/v1
DQ_LLM_MODEL=
#   e.g. for OpenRouter: DQ_LLM_MODEL=anthropic/claude-sonnet-4.6  (see openrouter.ai/models)
#   e.g. for local Ollama: DQ_LLM_BASE_URL=http://localhost:11434/v1  DQ_LLM_MODEL=llama3.3
# Note: MCP code-context servers are only attached on the anthropic provider.

# Per-request timeout / retries for LLM calls. Keep the timeout well below any
# reverse-proxy read timeout (nginx in the demo stack uses 300s).
DQ_LLM_TIMEOUT_SECONDS=90
DQ_LLM_MAX_RETRIES=1

# ---- Observability ----
DQ_LOG_FORMAT=text          # text | json (json recommended in containers)
DQ_LOG_LEVEL=INFO
DQ_WORKER_METRICS_PORT=9100 # worker Prometheus port; API serves /metrics
# GRAFANA_PASSWORD=admin    # docker compose Grafana admin password
DQ_LLM_MAX_EXPLORE_TURNS=8
DQ_LLM_MAX_RCA_TURNS=12
DQ_LLM_MAX_CHAT_TURNS=10    # tool-use turns per assistant chat answer

# Worker
DQ_WORKER_POLL_SECONDS=15
DQ_WORKER_CONCURRENCY=4

# CORS (comma-separated origins for the frontend dev server)
DQ_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ---- Notifications (optional; failed-run alerts — issue #27) ----
# All optional: with nothing set there are zero sends and zero behaviour change.
# Routing rules (which dataset/severity -> which channel) are managed in the UI
# (Settings -> Notifications, admin) and stored in the DB; these supply transport.
# Slack: a global incoming-webhook default for rules that leave their target blank.
# DQ_NOTIFY_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T000/B000/XXXX
# SMTP (email channel): host enables it; STARTTLS on by default.
# DQ_SMTP_HOST=smtp.example.com
# DQ_SMTP_PORT=587
# DQ_SMTP_USER=alerts@example.com
# DQ_SMTP_PASSWORD=app-password
# DQ_SMTP_FROM_ADDR=dq-sentinel@example.com
# DQ_SMTP_STARTTLS=true
# Incident notification channels (optional; issues #110/#112). Each provides
# transport credentials; routing rules are configured in Settings -> Notifications.
# Generic webhook: a global default target; payloads are HMAC-signed when a secret is set.
# DQ_WEBHOOK_URL=https://example.com/hooks/dq
# DQ_WEBHOOK_HMAC_SECRET=
# Microsoft Teams incoming webhook default.
# DQ_TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/XXXX
# PagerDuty Events API v2 routing key.
# DQ_PAGERDUTY_ROUTING_KEY=
# Jira (creates/updates issues for incidents).
# DQ_JIRA_BASE_URL=https://your-org.atlassian.net
# DQ_JIRA_EMAIL=alerts@example.com
# DQ_JIRA_API_TOKEN=
# DQ_JIRA_PROJECT_KEY=DQ
# DQ_JIRA_ISSUE_TYPE=Bug
# ServiceNow (creates/updates incident records).
# DQ_SERVICENOW_INSTANCE_URL=https://your-instance.service-now.com
# DQ_SERVICENOW_USER=
# DQ_SERVICENOW_PASSWORD=
# DQ_SERVICENOW_ASSIGNMENT_GROUP=
# Public base URL used to build links in alert bodies (-> /datasets/{id}/exceptions)
# DQ_BASE_URL=http://localhost:3000
