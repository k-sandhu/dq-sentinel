# ---- DQ Sentinel configuration (all values have dev defaults) ----

# App metadata database. Default: sqlite file under backend/.
# For production use PostgreSQL, e.g.:
# DQ_DATABASE_URL=postgresql+psycopg://dq:dq@localhost:5432/dqsentinel
DQ_DATABASE_URL=

# JWT signing secret — REQUIRED in production (any long random string)
DQ_SECRET_KEY=dev-only-secret-change-me
DQ_ACCESS_TOKEN_HOURS=12

# Seeded first admin (created only if no users exist)
DQ_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
DQ_BOOTSTRAP_ADMIN_PASSWORD=admin123

# LLM features (check generation, exploration, RCA). Optional —
# without a key the app falls back to heuristic check generation.
ANTHROPIC_API_KEY=
DQ_LLM_MODEL=claude-opus-4-8
DQ_LLM_MAX_EXPLORE_TURNS=8
DQ_LLM_MAX_RCA_TURNS=12

# Worker
DQ_WORKER_POLL_SECONDS=15
DQ_WORKER_CONCURRENCY=4

# CORS (comma-separated origins for the frontend dev server)
DQ_CORS_ORIGINS=http://localhost:5173,http://localhost:3000
